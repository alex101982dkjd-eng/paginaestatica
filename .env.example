# Variables de entorno para el envío de correos desde Netlify
# Copia este contenido en tu archivo .env local o en Netlify > Site settings > Environment variables

# Correo desde el cual se enviará el mensaje (tu cuenta real de Gmail o Outlook)
SMTP_USER=tu_correo@gmail.com

# Contraseña de aplicación o contraseña especial de la cuenta de correo
SMTP_PASS=tu_app_password_o_contraseña

# Correo al que llegan los mensajes enviados desde el formulario
CONTACT_TO=correo_destino@gmail.com
